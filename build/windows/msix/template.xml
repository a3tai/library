<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="Library"
        Arguments=""
        InstallLocation="C:\Program Files\A3T\Library">
    </Installer>
    <PackageInformation
        PackageName="Library"
        PackageDisplayName="A3T: Library"
        PublisherName="CN=A3T"
        PublisherDisplayName="A3T"
        Version="1.0.0.0"
        PackageDescription="Index and browse a local book library">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="ai.a3t.library"
                Description="Index and browse a local book library"
                DisplayName="A3T: Library"
                ExecutableName="Library"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>A3T: Library</DisplayName>
            <PublisherDisplayName>A3T</PublisherDisplayName>
            <Description>Index and browse a local book library</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="Library.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
