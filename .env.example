# Optional local development overrides. Copy to .env.local and fill in values
# for your machine; .env.local is ignored and must not be committed.

# LIBRARY_DB=/absolute/path/to/library.db
# LIBRARY_LMSTUDIO_URL=http://127.0.0.1:1234/v1
# LIBRARY_LMSTUDIO_MODEL=
# LIBRARY_LMSTUDIO_EMBED_MODEL=
# LIBRARY_LMSTUDIO_API_KEY=
# LIBRARY_PICKER=native
# LIBRARY_OTLP_ENDPOINT=http://127.0.0.1:4318
# LIBRARY_TRACE_STDOUT=1
